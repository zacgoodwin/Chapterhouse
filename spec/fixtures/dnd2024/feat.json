[
  {
    /* required, allowed locale keys - en, ru, es */
    "title": {
      "en": "Feature's title"
    },
    /* required, allowed locale keys - en, ru, es */
    "description": {
      "en": "Feature's description, **Markdown is available** for editing."
    },
    /* required, allowed values - static/text/update_result/hidden */
    /* static - Simple rendering */
    /* text - Like static + allow to add text value */
    /* update_result - Like static + can be hidden by settings */
    /* hidden - Always hidden */
    "kind": "static",
    /* required, available from level */
    "level": 1,
    /* optional */
    "limit": 1,
    /* optional, allowed values - short_rest/long_rest/one_at_short_rest */
    "limit_refresh": "short_rest",
    "origin": "feat",
    /* required, allowed values - origin/general/fighting_style/epic */
    /* origin - Background feats */
    /* general - Simple feats from 4 level */
    /* fighting_style - Fighting style feats */
    /* epic - Epic feats from 19 level */
    "origin_value": "origin",
    /* optional, true if feat need to turn on */
    "continious": true,
    /* optional, if feat gives innate spells */
    /* value can be ability for spell */
    /* or list of abilities, better is selected for bonuses */
    /* str/dex/con/int/wis/cha */
    "static_spells": {
      "Blade Ward": { "modifier": "int" },
      "Speak with Animals": { "modifier": ["int", "wis", "cha"] }
    },
    /* optional, one of abilities should be 13+ */
    /* str/dex/con/int/wis/cha */
    "ability_conditions": ["int", "wis"],
    /* optional, one of abilities can be up during level up */
    /* str/dex/con/int/wis/cha */
    "leveling_ability_boosts": ["int", "wis", "cha"],
    "public": true
  }
]
