<div class="max-w-7xl mx-auto flex-1 flex flex-col justify-center items-center">
  <%= form_with model: @user, url: signup_index_path, method: :post, class: 'p-4 bg-cosmos' do |form| %>
    <h2 class="text-2xl mb-4"><%= t('web.users.signup.title') %></h2>
    <div class="form-field mb-2">
      <%= form.label :username, t('web.users.signup.username'), class: 'form-label' %>
      <%= form.text_field :username, class: 'form-value w-full', required: true %>
    </div>
    <div class="form-field mb-2">
      <%= form.label :password, t('web.users.signup.password'), class: 'form-label' %>
      <%= form.password_field :password, class: 'form-value w-full', required: true %>
    </div>
    <div class="form-field mb-2">
      <%= form.label :password_confirmation, t('web.users.signup.confirmation'), class: 'form-label' %>
      <%= form.password_field :password_confirmation, class: 'form-value w-full', required: true %>
    </div>
    <div class="form-field uneditable-field">
      <%= form.text_field :bonus, class: 'form-value w-full' %>
    </div>
    <div class="mb-2 flex items-center gap-4">
      <% if Rails.env.production? %>
        <%= link_to omniauth_link(:google) do %>
          <%= image_tag 'google.svg', class: 'w-6 h-6', alt: 'google', width: 24, height: 24 %>
        <% end %>
        <%= link_to omniauth_link(:discord) do %>
          <%= image_tag 'discord.svg', class: 'w-6 h-6', alt: 'discord', width: 24, height: 24 %>
        <% end %>
      <% elsif Rails.env.ru_production? %>
        <%= link_to omniauth_link(:yandex) do %>
          <%= image_tag 'yandex.svg', class: 'w-6 h-6', alt: 'yandex', width: 24, height: 24 %>
        <% end %>
      <% else %>
        <%= link_to omniauth_link(:google) do %>
          <%= image_tag 'google.svg', class: 'w-6 h-6', alt: 'google', width: 24, height: 24 %>
        <% end %>
        <%= link_to omniauth_link(:discord) do %>
          <%= image_tag 'discord.svg', class: 'w-6 h-6', alt: 'discord', width: 24, height: 24 %>
        <% end %>
        <%= link_to omniauth_link(:yandex) do %>
          <%= image_tag 'yandex.svg', class: 'w-6 h-6', alt: 'yandex', width: 24, height: 24 %>
        <% end %>
      <% end %>
    </div>
    <div class="mb-2">
      <%= t('web.users.signup.have') %>
      <%= link_to t('web.users.signup.login'), new_signin_path, class: 'underline' %>
    </div>
    <%= form.submit t('web.users.signup.create'), class: 'btn btn-primary' %>
  <% end %>
</div>
