<%= form_with model: @item, scope: :item, url: adminbook_item_path(@item, provider: params[:provider]), method: 'patch', class: 'font-cascadia-light' do |form| %>
  <div class="form-field mb-2">
    <div><%= form.label 'Slug', class: 'form-label' %></div>
    <div><%= form.text_field :slug, class: 'form-value w-80', required: true %></div>
  </div>
  <%= form.fields_for :name, @item.name do |name_form| %>
    <div class="form-field mb-2">
      <div><%= name_form.label 'Name', class: 'form-label' %></div>
      <div><%= name_form.text_field :en, value: @item.name['en'], class: 'form-value w-80' %></div>
    </div>
  <% end %>
  <%= form.fields_for :description, @item.description do |description_form| %>
    <div class="form-field mb-2">
      <div><%= description_form.label 'Description', class: 'form-label' %></div>
      <div><%= description_form.textarea :en, value: @item.description['en'], class: 'form-text text-sm', size: '100x7' %></div>
    </div>
  <% end %>
  <div class="form-field mb-2">
    <div><%= form.label 'Kind', class: 'form-label' %></div>
    <div><%= form.text_field :kind, value: @item.kind, required: true, class: 'form-value w-80' %></div>
  </div>
  <div class="form-field mb-2">
    <div><%= form.label 'Weight/Price', class: 'form-label' %></div>
    <div><%= form.textarea :data, value: @item.data.attributes, class: 'form-text text-sm', required: true, size: '100x7' %></div>
  </div>
  <div class="form-field mb-2">
    <div><%= form.label 'Evaluation variables', class: 'form-label' %></div>
    <div><%= form.textarea :info, value: @item.info, class: 'form-text text-sm', required: true, size: '100x7' %></div>
  </div>
  <%= form.submit 'Update', class: 'btn btn-primary' %>
<% end %>
