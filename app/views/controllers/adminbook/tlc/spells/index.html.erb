<%= render 'adminbook/tlc/toolbar' %>
<table class="table w-full text-sm font-cascadia-light">
  <thead>
    <tr>
      <td>Slug</td>
      <td>Name</td>
      <td>Visibility</td>
      <td>Verified</td>
      <td></td>
    </tr>
  </thead>
  <tbody>
    <% @records.each do |spell| %>
      <tr>
        <td class="pr-4"><%= link_to spell.slug, edit_adminbook_tlc_spell_path(spell.id), class: 'underline text-blue-400' %></td>
        <td class="pr-4"><%= spell.name['en'] %></td>
        <td class="pr-4"><%= spell.visibility %></td>
        <td class="pr-4"><%= spell.verified? ? 'yes' : 'NO' %></td>
        <td><%= button_to 'X', adminbook_tlc_spell_path(spell.id), method: :delete, class: 'btn-warning btn-small text-sm' %></td>
      </tr>
    <% end %>
  </tbody>
</table>
