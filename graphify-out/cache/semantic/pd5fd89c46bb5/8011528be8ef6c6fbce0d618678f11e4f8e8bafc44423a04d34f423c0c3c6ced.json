{"nodes": [{"id": "docs_leyfarers_implementation_plan_document", "label": "Leyfarers (TLC) Implementation Plan", "file_type": "document", "source_file": "docs/leyfarers-implementation-plan.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "APPROVED /autoplan plan (2026-07-19) to turn Chapterhouse into the Leyfarers app; default landing tab Combat; session date TBD."}, {"id": "docs_leyfarers_implementation_plan_tlc_provider", "label": "TLC Provider (Tlc::Character)", "file_type": "concept", "source_file": "docs/leyfarers-implementation-plan.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "New STI type Tlc::Character with provider slug 'tlc', following the extension pattern; CharacterData adds leyfarer_rank, leyfarer_focus, selected_traits, mixed_species, dismissed_warnings. Character.tlc scope stays STRICT for endpoint authorization."}, {"id": "docs_leyfarers_implementation_plan_tlc_decorator", "label": "TlcDecorator < Dnd2024Decorator", "file_type": "concept", "source_file": "docs/leyfarers-implementation-plan.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "TLC is 2024 latest-printing-wins with deltas; subclass and override only deltas (alternate AC, trait senses, rank perks, human multiclass bypass, species-step override, static-spell widening). Parity spec is the alarm for upstream refactors."}, {"id": "docs_leyfarers_implementation_plan_premise_build_on_stack", "label": "Premise P1: Build on Existing Stack", "file_type": "concept", "source_file": "docs/leyfarers-implementation-plan.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Rails 8.1 + SolidJS + esbuild; the design doc's React/Next/Node stack table (all rows marked '(?)') is superseded by the codebase the doc itself names as inspiration. No rewrite."}, {"id": "docs_leyfarers_implementation_plan_premise_new_provider", "label": "Premise P2: TLC New Provider (not edit dnd2024)", "file_type": "concept", "source_file": "docs/leyfarers-implementation-plan.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Keeps stock dnd2024 usable and keeps TLC additive for upstream merges; Approach A chosen over B (homebrew-only, 4/10 completeness) and C (edit dnd2024 in place). Confirmed by Zac at the premise gate."}, {"id": "docs_leyfarers_implementation_plan_premise_content_is_data", "label": "Premise P4: Content is Data (union, not copied)", "file_type": "concept", "source_file": "docs/leyfarers-implementation-plan.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "TLC options return the union of dnd2024 content + TLC-only rows minus the banned list; nothing from the 2024 corpus is duplicated. Copying would fork from upstream errata and double entry burden. Answers the design doc's structured-vs-JSON question with the existing modifiers pattern."}, {"id": "docs_leyfarers_implementation_plan_premise_mvp_party_plays", "label": "Premise P5: MVP = Party Plays", "file_type": "concept", "source_file": "docs/leyfarers-implementation-plan.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Measurable outcome: the campaign's actual PCs rebuilt in the app and used at the table. Content entry is party-first; PDF/share/offline/admin/companions are phased behind it."}, {"id": "docs_leyfarers_implementation_plan_phase_a0", "label": "Phase A0: Validation Spikes", "file_type": "concept", "source_file": "docs/leyfarers-implementation-plan.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Homebrew-UI spike (route one full species + subclass) + modifiers expressiveness exercise (encode 10 hairiest traits as modifiers JSONB) before any provider code; prices content entry and de-risks the modifier model."}, {"id": "docs_leyfarers_implementation_plan_phase_a", "label": "Phase A: Provider Skeleton", "file_type": "concept", "source_file": "docs/leyfarers-implementation-plan.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Backend platforms/tlc + decorator + builders + commands + routes/serializers; frontend data/tlc.json, CharacterTab match, isDnd2024Family helper, client-side tlcConfig deep-merge module."}, {"id": "docs_leyfarers_implementation_plan_phase_b", "label": "Phase B: TLC Content Seeding", "file_type": "concept", "source_file": "docs/leyfarers-implementation-plan.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "B1 party-first (gates MVP) then B2 full-corpus scripted backfill; garbled tables seed verified:false and require human check before merge."}, {"id": "docs_leyfarers_implementation_plan_phase_c", "label": "Phase C: TLC Mechanics", "file_type": "concept", "source_file": "docs/leyfarers-implementation-plan.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Leyfarer Rank + rank-perk feats, campaign chapter setting + level-cap warning, Session Rest, subclass resources, decorator overrides, soft-warning engine, and a minimal visible TLC surface (rank/Focus badge, warnings, session-rest button)."}, {"id": "docs_leyfarers_implementation_plan_phase_d", "label": "Phase D: TLC UX Layer", "file_type": "concept", "source_file": "docs/leyfarers-implementation-plan.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Full design-doc screens: Tlc.jsx with Aptitudes and Breaks tabs, minimal conditions, override affordances, warnings summary. Wireframes from the doc's own mockup images (2-9) gate every component; land on Combat; 390px mobile-first, 44px targets."}, {"id": "docs_leyfarers_implementation_plan_phase_e", "label": "Phase E: Admin + Homebrew Completeness", "file_type": "concept", "source_file": "docs/leyfarers-implementation-plan.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "adminbook/tlc CRUD with 4-state visibility + verified flag; platforms/tlc/homebrews + homebrews_v2/tlc mirroring dnd2024. Post-MVP fast-follow; never gates test 0."}, {"id": "docs_leyfarers_implementation_plan_banned_spell_filter", "label": "Banned-Spell Filter + Seed Lint", "file_type": "concept", "source_file": "docs/leyfarers-implementation-plan.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Exclusion applied in the tlc spell options path AND the grants pipeline; a seed-time lint fails on any content row auto-granting a banned spell unless it carries banned_exemption:true; exempted grants still emit a TLC soft warning. Systematic rule that catches the Lady of Ivory -> Fabricate class of conflict."}, {"id": "docs_leyfarers_implementation_plan_soft_warning_engine", "label": "Soft-Warning Engine (decorator)", "file_type": "concept", "source_file": "docs/leyfarers-implementation-plan.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Decorator computes a warnings array {slug, source PHB|TLC, message_key, dismissible} for multiclass prereqs, trait count, prepared-spell overrun, level-vs-chapter cap; dismissals persist in data.dismissed_warnings, keyed by slug only (no context-hash re-arming)."}, {"id": "docs_leyfarers_implementation_plan_union_options_query", "label": "Union Content Options Query", "file_type": "concept", "source_file": "docs/leyfarers-implementation-plan.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Content models (Feat/Spell/Item) expose tlc_content = where(type IN ['Dnd2024::*','Tlc::*']); single type IN query, index-backed. The Character scope stays strict; union applies only to content."}, {"id": "docs_leyfarers_implementation_plan_tlc_seed_idempotent", "label": "rake tlc:seed + Partial Unique Index", "file_type": "concept", "source_file": "docs/leyfarers-implementation-plan.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The legacy db/seeds.rb is NOT idempotent (create! + upsert_all without unique_by; no unique index on slug). TLC ships its own rake task + a migration adding a partial unique (type, slug) index, seeding via upsert_all(unique_by:)."}, {"id": "docs_leyfarers_implementation_plan_trait_selection_flow", "label": "Trait Selection Flow (selected_traits)", "file_type": "concept", "source_file": "docs/leyfarers-implementation-plan.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Traits are Tlc::Feat rows (origin species_trait); the TLC refresh service attaches trait feats explicitly from selected_traits (species_trait origin kept OUT of SELECTABLE_ORIGINS so deselection detaches). Nonexistent slug = 422; rule-breaking but real selection = soft warning, never block."}, {"id": "docs_leyfarers_implementation_plan_platform_config_merge", "label": "PlatformConfig base:dnd2024 Deep-Merge", "file_type": "concept", "source_file": "docs/leyfarers-implementation-plan.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "data/tlc.json composes with dnd2024 config via one explicit deep-merge point in platform_config.rb; a client-side data/tlcConfig.js mirrors it because the SPA imports config JSON statically."}, {"id": "docs_leyfarers_implementation_plan_rest_command_override", "label": "Tlc Rest-Command Session Override", "file_type": "concept", "source_file": "docs/leyfarers-implementation-plan.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The inherited long-rest command blanket-resets ALL feats (feats.update_all(used_count:0)); Tlc::MakeLongRestCommand (and short) excludes limit_refresh:session so only rest_type=session refreshes those. Rest apply is a single transaction with a double-submit guard on hit-dice spends."}, {"id": "docs_leyfarers_implementation_plan_scripted_extraction", "label": "Scripted PDF Content Extraction", "file_type": "concept", "source_file": "docs/leyfarers-implementation-plan.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "bin/extract-tlc-content parses pdftotext -layout output of the Players Guide into db/data/tlc/*.json with a review diff; deterministic-space work, not hand-typed. Garbled tables hand-verified."}, {"id": "docs_leyfarers_implementation_plan_dentaku_rescue", "label": "Dentaku Rescue-and-Log + Formula Lint", "file_type": "concept", "source_file": "docs/leyfarers-implementation-plan.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A bad seeded/homebrew formula must not 500 the sheet: rescue per-modifier, log slug+formula+character, skip that modifier only. A formula lint spec iterates every seeded TLC modifier and fails on any unparseable/unbound formula."}, {"id": "docs_leyfarers_implementation_plan_acceptance_test_0", "label": "Acceptance Test 0 (Party Plays)", "file_type": "concept", "source_file": "docs/leyfarers-implementation-plan.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Every current party PC rebuilt and used at a named session with TLC state VISIBLE and actionable (rank badge, warnings list, session-rest button) - not just present in the API. Session date TBD; gates on A0+A+B1+C only."}, {"id": "docs_leyfarers_implementation_plan_minimal_conditions", "label": "Minimal Conditions (Effects engine deferred)", "file_type": "concept", "source_file": "docs/leyfarers-implementation-plan.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Conditions expressible as modifiers (e.g. exhaustion) apply via character_bonus; the rest render as informational badges. Full effect automation (advantage propagation, per-roll riders) is a known ponytail ceiling deferred with the Effects engine."}, {"id": "docs_leyfarers_implementation_plan_kill_criterion", "label": "Kill Criterion (fallback to dnd2024)", "file_type": "concept", "source_file": "docs/leyfarers-implementation-plan.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "If acceptance test 0 isn't achievable by the session date, fall back to stock dnd2024 + homebrew content + paper tracking for TLC mechanics, and re-plan. Stays unarmed until Zac sets the date."}], "edges": [{"source": "docs_leyfarers_implementation_plan_document", "target": "docs_codebase_map_document", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/leyfarers-implementation-plan.md", "source_location": null, "weight": 1.0}, {"source": "docs_leyfarers_implementation_plan_document", "target": "docs_design_doc_digest_document", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/leyfarers-implementation-plan.md", "source_location": null, "weight": 1.0}, {"source": "docs_leyfarers_implementation_plan_document", "target": "docs_players_guide_digest_document", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/leyfarers-implementation-plan.m